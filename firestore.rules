rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Products - users can read approved, admin can write
    match /products/{productId} {
      allow read: if true; // All can read products
      allow create, update, delete: if request.auth != null;
    }
    
    // Orders - users own orders + admin read all
    match /orders/{orderId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }
    
    // All users can read/write orders (for demo)
    match /orders/{orderId} {
      allow read, write: if true;
    }
    
    // Transactions
    match /transactions/{transactionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Support tickets
    match /support_tickets/{ticketId} {
      allow read, create: if true;
      allow update: if request.auth != null;
    }
    
    // Phone OTPs
    match /phone_otps/{otpId} {
      allow read, write: if true; // Temp data
    }
    
    // Admin notifications
    match /admin_notifications/{notifId} {
      allow read, write: if request.auth != null;
    }
    
    // Notifications
    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }
    
    // Malls
    match /malls/{mallId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow all operations for development (update for production)
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
